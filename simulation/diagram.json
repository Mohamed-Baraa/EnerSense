  "connections": [
    ["esp32:GND.1",      "gnd1:GND",       "black",  []],
    ["esp32:3V3",        "vcc1:VCC",        "red",    []],

    ["pot_current:SIG",  "esp32:IO34",      "orange", []],
    ["pot_current:VCC",  "vcc1:VCC",        "red",    []],
    ["pot_current:GND",  "gnd1:GND",        "black",  []],

    ["pot_voltage:SIG",  "esp32:IO35",      "yellow", []],
    ["pot_voltage:VCC",  "vcc1:VCC",        "red",    []],
    ["pot_voltage:GND",  "gnd1:GND",        "black",  []],

    ["esp32:IO26",       "relay1:IN",       "purple", []],
    ["relay1:VCC",       "vcc1:VCC",        "red",    []],
    ["relay1:GND",       "gnd1:GND",        "black",  []],

    ["esp32:IO26",       "r_relay:1",       "purple", []],
    ["r_relay:2",        "led_relay:A",     "purple", []],
    ["led_relay:K",      "gnd1:GND",        "black",  []],

    ["esp32:IO2",        "r_status:1",      "green",  []],
    ["r_status:2",       "led_status:A",    "green",  []],
    ["led_status:K",     "gnd1:GND",        "black",  []]
  ]
