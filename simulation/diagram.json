{
  "version": 1,
  "author": "EnerSense Team",
  "editor": "wokwi",
  "parts": [
    {
      "type": "board-esp32-devkit-v1",
      "id": "esp32",
      "top": 160,
      "left": 240,
      "attrs": {}
    },

    {
      "type": "wokwi-potentiometer",
      "id": "pot_current",
