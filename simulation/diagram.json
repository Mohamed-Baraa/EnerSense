      "left": 20,
      "attrs": { "value": "512" },
      "label": "ACS712 (current)"
    },

    {
      "type": "wokwi-potentiometer",
      "id": "pot_voltage",
      "top": 20,
      "left": 180,
      "attrs": { "value": "2048" },
      "label": "ZMPT101B (voltage)"
    },

    {
      "type": "wokwi-relay-module",
      "id": "relay1",
      "top": 160,
      "left": 560,
      "attrs": {}
    },

    {
      "type": "wokwi-led",
      "id": "led_relay",
      "top": 100,
      "left": 600,
      "attrs": { "color": "red" },
      "label": "Relay ON indicator"
    },

    {
      "type": "wokwi-led",
      "id": "led_status",
      "top": 100,
      "left": 660,
      "attrs": { "color": "green" },
      "label": "Wi-Fi / MQTT status"
    },

    {
      "type": "wokwi-resistor",
      "id": "r_relay",
      "top": 130,
      "left": 600,
      "attrs": { "value": "220" }
    },

    {
      "type": "wokwi-resistor",
      "id": "r_status",
      "top": 130,
      "left": 660,
      "attrs": { "value": "220" }
    },

    {
      "type": "wokwi-vcc",
      "id": "vcc1",
      "top": -20,
      "left": 400,
      "attrs": {}
    },

    {
      "type": "wokwi-gnd",
      "id": "gnd1",
      "top": 420,
      "left": 400,
      "attrs": {}
    }
