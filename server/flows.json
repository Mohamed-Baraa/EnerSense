    {
        "id": "2a461b0dcb99258f",
        "type": "function",
        "z": "cdbcf4272efad590",
        "name": "Anomaly check",
        "func": "const P = msg.payload.P_W;\nif (P > 2500) {\n  msg.payload = '⚠ ANOMALY: ' + P.toFixed(1) + ' W @ ' + new Date().toLocaleTimeString();\n  return msg;\n}\nif (msg.payload.anomaly) {\n  msg.payload = '⚠ Flagged by ESP32: ' + P.toFixed(1) + ' W @ ' + new Date().toLocaleTimeString();\n  return msg;\n}\nreturn null;",
        "outputs": 1,
        "x": 540,
        "y": 200,
        "wires": [
            [
                "e667f9c20e84a1cc"
            ]
        ]
    },
    {
        "id": "e0fa4134213abf9a",
        "type": "function",
        "z": "cdbcf4272efad590",
        "name": "Daily cost",
        "func": "const TARIFF = 0.180;\nconst key = 'daily_kwh';\nlet daily = flow.get(key) || 0;\nconst prev = flow.get('prev_ewh') || 0;\nconst curr = msg.payload.E_Wh || 0;\nif (curr >= prev) daily += (curr - prev) / 1000.0;\nflow.set(key, daily);\nflow.set('prev_ewh', curr);\n\n// Track hourly kWh for ML lag features\nconst kwh_now = (msg.payload.P_W || 0) / 1000.0;\nlet history = flow.get('kwh_history') || [];\nhistory.push(kwh_now);\nif (history.length > 180) history = history.slice(-180); // keep last 3 min\nflow.set('kwh_history', history);\n\n// Compute lag values (average over last 60 readings per hour slot)\nconst n = history.length;\nflow.set('lag_1h', history.slice(-60).reduce((a, b) => a + b, 0) / Math.min(60, n));\nflow.set('lag_2h', history.slice(-120, -60).reduce((a, b) => a + b, 0) / Math.min(60, n));\nflow.set('lag_3h', history.slice(-180, -120).reduce((a, b) => a + b, 0) / Math.min(60, n));\n\nconst out = msg;\nout.daily_kwh = daily.toFixed(4);\nout.daily_cost = (daily * TARIFF).toFixed(4);\nreturn out;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 540,
        "y": 240,
        "wires": [
            [
                "d13817e404c76a95",
                "7e81a96fc7719195"
            ]
        ]
    },
