        "name": "Enrich",
        "func": "const parts = msg.topic.split('/');\nmsg.node_id = parts[1] || 'node_01';\nmsg.appliance_id = parts[2] || 'appliance_01';\nmsg.ts_ms = msg.payload.ts_ms || Date.now();\nif (!msg.payload.P_W) return null;\nreturn msg;",
