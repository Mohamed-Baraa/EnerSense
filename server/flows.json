        "func": "if (!msg.payload || !msg.payload.forecast) return null;\nconst lines = msg.payload.forecast.map(f =>\n    `${String(f.hour).padStart(2, '0')}:00  →  ${f.predicted_w} W  (${f.predicted_kwh} kWh)`\n);\nlines.push(`─────────────────────────`);\nlines.push(`Total: ${msg.payload.total_kwh} kWh`);\nmsg.payload = lines.join('\\n');\nreturn msg;",
